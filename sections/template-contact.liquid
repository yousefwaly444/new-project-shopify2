{% comment %}
  Modern Contact page section.
  Assign template "contact" to your Contact page in Theme Editor.
{% endcomment %}

<div class="contact-page" style="--contact-accent: {{ section.settings.accent_color }};">
  <div class="contact-page__container">
    {% if page.title != blank %}
      <header class="contact-page__header">
        <h1 class="contact-page__title">{{ page.title }}</h1>
        {% if page.content != blank %}
          <div class="contact-page__intro rte">{{ page.content }}</div>
        {% endif %}
      </header>
    {% endif %}

    <div class="contact-page__form-wrap">
      {% form 'contact', class: 'contact-form' %}
        {% if form.posted_successfully? %}
          <p class="contact-form__success" role="status">
            Thank you for your message. We'll get back to you soon.
          </p>
        {% endif %}

        {% if form.errors %}
          <div class="contact-form__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="contact-form__row">
          <label for="ContactFormName" class="contact-form__label">Name</label>
          <input
            type="text"
            id="ContactFormName"
            name="contact[name]"
            class="contact-form__input"
            autocomplete="name"
            value="{{ form.name }}"
            required
          >
        </div>
        <div class="contact-form__row">
          <label for="ContactFormEmail" class="contact-form__label">Email</label>
          <input
            type="email"
            id="ContactFormEmail"
            name="contact[email]"
            class="contact-form__input"
            autocomplete="email"
            value="{{ form.email }}"
            required
          >
        </div>
        <div class="contact-form__row">
          <label for="ContactFormPhone" class="contact-form__label">Phone <span class="contact-form__optional">(optional)</span></label>
          <input
            type="tel"
            id="ContactFormPhone"
            name="contact[phone]"
            class="contact-form__input"
            autocomplete="tel"
            value="{{ form.phone }}"
          >
        </div>
        <div class="contact-form__row">
          <label for="ContactFormMessage" class="contact-form__label">Message</label>
          <textarea
            id="ContactFormMessage"
            name="contact[body]"
            class="contact-form__textarea"
            rows="5"
            required
          >{{ form.body }}</textarea>
        </div>
        <div class="contact-form__row contact-form__submit-row">
          <button type="submit" class="contact-form__submit">
            Send message
          </button>
        </div>
      {% endform %}
    </div>

    <div class="contact-page__back">
      <a href="{{ routes.root_url }}" class="contact-page__back-link">
        <svg class="contact-page__back-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to home
      </a>
    </div>
  </div>
</div>

<style>
  .contact-page {
    padding: 2.5rem 1.25rem 4rem;
    min-height: 60vh;
    background: linear-gradient(180deg, #fafafa 0%, #ffffff 12rem);
  }
  @media (min-width: 768px) {
    .contact-page { padding: 3.5rem 1.5rem 5rem; }
  }

  .contact-page__container {
    max-width: 560px;
    margin: 0 auto;
  }

  .contact-page__header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .contact-page__title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #111827;
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
  }

  .contact-page__intro {
    font-size: 1rem;
    line-height: 1.6;
    color: #6b7280;
    margin: 0;
  }
  .contact-page__intro.rte p { margin: 0 0 0.5rem 0; }

  .contact-form__success {
    padding: 1rem 1.25rem;
    background: #ecfdf5;
    color: #065f46;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
  }

  .contact-form__errors {
    padding: 1rem 1.25rem;
    background: #fef2f2;
    color: #991b1b;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
  }

  .contact-form__row {
    margin-bottom: 1.25rem;
  }

  .contact-form__label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 0.375rem;
  }

  .contact-form__optional {
    font-weight: 400;
    color: #9ca3af;
  }

  .contact-form__input,
  .contact-form__textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    line-height: 1.5;
    color: #111827;
    background: #fff;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  .contact-form__input:focus,
  .contact-form__textarea:focus {
    outline: none;
    border-color: var(--contact-accent, #111827);
    box-shadow: 0 0 0 3px rgba(17, 24, 39, 0.1);
  }
  .contact-form__textarea {
    min-height: 120px;
    resize: vertical;
  }

  .contact-form__submit-row {
    margin-top: 1.5rem;
    margin-bottom: 0;
  }

  .contact-form__submit {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    background: var(--contact-accent, #111827);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .contact-form__submit:hover {
    opacity: 0.9;
  }

  .contact-page__back {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e5e7eb;
  }

  .contact-page__back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--contact-accent, #111827);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .contact-page__back-link:hover { opacity: 0.8; }

  .contact-page__back-icon { flex-shrink: 0; }
</style>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (buttons, links)",
      "default": "#111827"
    }
  ],
  "presets": [
    {
      "name": "Contact Page"
    }
  ]
}
{% endschema %}
